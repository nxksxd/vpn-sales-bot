# ============================
# VPN Bot Configuration
# ============================

# --- Telegram ---
# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here
# Admin Telegram ID (only this user gets admin panel)
ADMIN_TELEGRAM_ID=123456789

# --- Database ---
# SQLite (default, for development/small deployments):
DATABASE_URL=sqlite+aiosqlite:///./vpn_bot.db
# PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/vpn_bot

# --- 3x-ui Panel ---
# Panel URL (include port and base path if any)
XUI_URL=https://your-server.com:2053
# Panel login credentials
XUI_USERNAME=admin
XUI_PASSWORD=your_panel_password
# Inbound ID for creating new VLESS clients
XUI_INBOUND_ID=1

# --- Server ---
# Public IP or domain for VLESS links
SERVER_ADDRESS=your-server-ip-or-domain

# --- Subscription Plans (Telegram Stars) ---
PLAN_1M_STARS=100
PLAN_3M_STARS=250
PLAN_6M_STARS=450
PLAN_12M_STARS=800

# --- Traffic ---
# Traffic limit per client in GB (0 = unlimited)
TRAFFIC_LIMIT_GB=0

# --- Referral System ---
# Stars bonus for each referred user
REFERRAL_BONUS_STARS=10

# --- Notifications ---
# Comma-separated days before expiry to send reminders
NOTIFY_BEFORE_DAYS=3,1

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=30

# --- Support ---
# Telegram username for support contact (without @)
SUPPORT_USERNAME=your_support_username
