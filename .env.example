# ============================
# Портальный ключ — Configuration
# ============================

# --- Telegram ---
# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here
# Admin Telegram ID (only this user gets admin panel)
ADMIN_TELEGRAM_ID=123456789

# --- Database ---
# PostgreSQL (recommended for production and the default for Docker Compose):
POSTGRES_USER=vpn_bot
POSTGRES_PASSWORD=change_me
POSTGRES_DB=vpn_bot
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://vpn_bot:change_me@postgres:5432/vpn_bot
# SQLite (optional, mostly for local development):
# DATABASE_URL=sqlite+aiosqlite:///./vpn_bot.db

# --- 3x-ui Panel ---
# Panel URL (include port and base path if any)
XUI_URL=https://your-server.com:2053
# Panel login credentials
XUI_USERNAME=admin
XUI_PASSWORD=your_panel_password
# Inbound ID for creating new VLESS clients
XUI_INBOUND_ID=1
# XTLS flow for new VLESS clients (applied only to REALITY inbounds).
# Standard for VLESS+REALITY is "xtls-rprx-vision". Leave empty if your
# inbound does not use it (e.g. VLESS+TLS+WS).
XUI_FLOW=xtls-rprx-vision

# --- Subscription URL (3x-ui /sub/<subId>) ---
# Public base URL the bot will send to users (without trailing slash).
# Leave empty to reuse XUI_URL. Typically this is the panel host on the
# "subscription" port configured in 3x-ui (Panel Settings → Subscription).
# Example: SUBSCRIPTION_URL_BASE=https://your-server.com:2096
SUBSCRIPTION_URL_BASE=
# Path prefix from 3x-ui subscription settings (must match the panel).
SUBSCRIPTION_PATH=/sub/

# --- Server ---
# Public IP or domain for VLESS links
SERVER_ADDRESS=your-server-ip-or-domain

# --- Subscription Plans (prices in rubles) ---
PLAN_1M_RUB=200
PLAN_3M_RUB=500
PLAN_6M_RUB=900
PLAN_12M_RUB=1600

# --- Stars to Rubles conversion ---
# 1 Star = X rubles
STARS_TO_RUB_RATE=2.0

# --- Traffic ---
# Traffic limit per client in GB (0 = unlimited)
TRAFFIC_LIMIT_GB=0

# Device limit per client — max simultaneous IPs (0 = unlimited)
DEVICE_LIMIT=0

# --- Referral System ---
# Base bonus in rubles for each referred user (used when no tier matches)
REFERRAL_BONUS_RUB=20
# Optional tiered bonuses by total referral count (JSON). Empty list = flat bonus.
# Example: more referrals -> higher per-referral bonus:
# REFERRAL_TIERS_JSON=[{"min_referrals": 5, "bonus_rub": 30}, {"min_referrals": 20, "bonus_rub": 50}]
REFERRAL_TIERS_JSON=[]

# --- Notifications ---
# Comma-separated days before expiry to send reminders
NOTIFY_BEFORE_DAYS=3,1

# --- Rate Limiting ---
RATE_LIMIT_PER_MINUTE=30

# --- Support ---
# Telegram username for support contact (without @)
SUPPORT_USERNAME=your_support_username

# --- YooKassa ---
# Shop ID and Secret Key from https://yookassa.ru/my/shop-settings
# Leave both empty to disable YooKassa payments (only Stars will be available).
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# URL where user returns after payment (typically your bot link)
YOOKASSA_RETURN_URL=https://t.me/portalkey_bot
# Port for webhook server (must be accessible from the internet)
YOOKASSA_WEBHOOK_PORT=8080

# --- Encryption ---
# Key for encrypting sensitive DB fields (VLESS links, emails) at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty ONLY for local dev (fields will be stored in plaintext).
ENCRYPTION_KEY=
